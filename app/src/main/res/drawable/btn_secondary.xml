<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/btn_soft_shadow" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
            <item
                android:bottom="2dp"
                android:right="2dp"
                android:left="2dp"
                android:top="2dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="135"
                        android:centerColor="@color/btn_secondary_press"
                        android:endColor="@color/light_blue"
                        android:startColor="@color/btn_secondary_fill"
                        android:type="linear" />
                    <corners android:radius="16dp" />
                    <stroke
                        android:width="2dp"
                        android:color="@color/btn_secondary_dark"
                        android:dashWidth="6dp"
                        android:dashGap="4dp" />
                </shape>
            </item>
            <item
                android:bottom="2dp"
                android:right="2dp"
                android:left="2dp"
                android:top="2dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="90"
                        android:endColor="#00FFFFFF"
                        android:startColor="#55FFFFFF"
                        android:type="linear" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/btn_soft_shadow" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
            <item
                android:bottom="4dp"
                android:right="4dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="135"
                        android:centerColor="@color/btn_secondary_fill"
                        android:endColor="@color/light_blue"
                        android:startColor="@color/white"
                        android:type="linear" />
                    <corners android:radius="16dp" />
                    <stroke
                        android:width="2dp"
                        android:color="@color/primary_blue"
                        android:dashWidth="6dp"
                        android:dashGap="4dp" />
                </shape>
            </item>
            <item
                android:bottom="4dp"
                android:right="4dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="90"
                        android:centerColor="#18FFFFFF"
                        android:endColor="#00FFFFFF"
                        android:startColor="#55FFFFFF"
                        android:type="linear" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
