<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_menu_clean"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/header_gradient_blue"
        android:elevation="6dp"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvSeleccionTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/seleccion_titulo"
            android:textColor="@color/text_light"
            android:textSize="24sp"
            android:fontFamily="@font/nunito_extrabold"
            android:textStyle="normal" />

        <TextView
            android:id="@+id/tvNombreEjercicio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textColor="@color/text_light"
            android:textSize="18sp"
            android:fontFamily="@font/nunito_semibold"
            android:textStyle="normal" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnFacil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/button_rounded_green"
            android:padding="20dp"
            android:text="@string/dificultad_facil"
            android:textColor="@color/text_light"
            android:textSize="22sp"
            android:fontFamily="@font/nunito_extrabold"
            android:textStyle="normal"
            android:textAllCaps="false" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:text="@string/dificultad_facil_desc"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/nunito_semibold"
            android:textStyle="normal" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnMedio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/button_rounded_orange"
            android:padding="20dp"
            android:text="@string/dificultad_medio"
            android:textColor="@color/text_light"
            android:textSize="22sp"
            android:fontFamily="@font/nunito_extrabold"
            android:textStyle="normal"
            android:textAllCaps="false" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:text="@string/dificultad_medio_desc"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/nunito_semibold"
            android:textStyle="normal" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDificil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/button_rounded_red"
            android:padding="20dp"
            android:text="@string/dificultad_dificil"
            android:textColor="@color/text_light"
            android:textSize="22sp"
            android:fontFamily="@font/nunito_extrabold"
            android:textStyle="normal"
            android:textAllCaps="false" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/dificultad_dificil_desc"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/nunito_semibold"
            android:textStyle="normal" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnAtrasSeleccion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/historial_atras"
            style="@style/KidAppButtonSecondary" />
    </LinearLayout>
</LinearLayout>
