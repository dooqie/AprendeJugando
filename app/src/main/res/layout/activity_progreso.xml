<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_menu_clean"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tu Progreso"
            android:textSize="28sp"
            android:fontFamily="@font/nunito_extrabold"
            android:textStyle="normal"
            android:textColor="#1976D2"
            android:layout_gravity="center"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvSinDatos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¡Aún no tienes datos! Juega algunos ejercicios para ver tu progreso."
            android:textSize="16sp"
            android:fontFamily="@font/nunito_semibold"
            android:textStyle="normal"
            android:textColor="#666"
            android:visibility="gone"
            android:layout_gravity="center"
            android:padding="32dp" />

        <!-- Gráfico de barras -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aciertos por ejercicio"
            android:textSize="18sp"
            android:fontFamily="@font/nunito_semibold"
            android:textStyle="normal"
            android:textColor="#333"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <com.github.mikephil.charting.charts.BarChart
            android:id="@+id/barChart"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:background="#FFFFFF"
            android:padding="8dp" />

        <!-- Gráfico circular -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Distribución de ejercicios"
            android:textSize="18sp"
            android:fontFamily="@font/nunito_semibold"
            android:textStyle="normal"
            android:textColor="#333"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />

        <com.github.mikephil.charting.charts.PieChart
            android:id="@+id/pieChart"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:background="#FFFFFF"
            android:padding="8dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnVolverProgreso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Volver"
            android:onClick="onVolverClicked"
            android:layout_marginTop="24dp"
            style="@style/KidAppButtonSecondary" />

    </LinearLayout>
</ScrollView>