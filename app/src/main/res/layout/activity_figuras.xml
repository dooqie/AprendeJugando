<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/juegoLayoutFiguras"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_purple"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/cardInfoFiguras"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="vertical"
        android:background="@drawable/card_ejercicio_info_bg"
        android:elevation="4dp"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/nivelTextViewFiguras"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/nunito_semibold"
                android:textStyle="normal"
                android:gravity="start"
                android:text="Nivel: 1"
                android:textColor="@color/text_primary"
                android:textSize="28sp" />

            <TextView
                android:id="@+id/timerTextViewFiguras"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:fontFamily="@font/nunito_semibold"
                android:textStyle="normal"
                android:text="Tiempo: 60"
                android:textColor="@color/text_primary"
                android:textSize="28sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/scoreTextViewFiguras"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:fontFamily="@font/nunito_semibold"
            android:textStyle="normal"
            android:text="Aciertos: 0 | Fallos: 0"
            android:textColor="@color/text_primary"
            android:textSize="22sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/opcionesContainerFiguras"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/btnVolverFiguras"
        android:layout_marginBottom="16dp"
        android:orientation="vertical"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/opcion1ButtonFiguras"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="88dp"
                android:gravity="center"
                android:textAlignment="center"
                android:maxLines="2"
                android:ellipsize="end"
                android:text="Círculo"
                android:textSize="20sp"
                android:fontFamily="@font/nunito_extrabold"
                android:textStyle="normal"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:background="@drawable/button_rounded_purple"
                android:layout_margin="8dp" />

            <Button
                android:id="@+id/opcion2ButtonFiguras"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="88dp"
                android:gravity="center"
                android:textAlignment="center"
                android:maxLines="2"
                android:ellipsize="end"
                android:text="Cuadrado"
                android:textSize="20sp"
                android:fontFamily="@font/nunito_extrabold"
                android:textStyle="normal"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:background="@drawable/button_rounded_pink"
                android:layout_margin="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/opcion3ButtonFiguras"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="88dp"
                android:gravity="center"
                android:textAlignment="center"
                android:maxLines="2"
                android:ellipsize="end"
                android:text="Triángulo"
                android:textSize="20sp"
                android:fontFamily="@font/nunito_extrabold"
                android:textStyle="normal"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:background="@drawable/button_rounded_yellow"
                android:layout_margin="8dp" />

            <Button
                android:id="@+id/opcion4ButtonFiguras"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="88dp"
                android:gravity="center"
                android:textAlignment="center"
                android:maxLines="2"
                android:ellipsize="end"
                android:text="Rectángulo"
                android:textSize="20sp"
                android:fontFamily="@font/nunito_extrabold"
                android:textStyle="normal"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:background="@drawable/button_rounded_cyan"
                android:layout_margin="8dp" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/cardInfoFiguras"
        android:layout_above="@id/opcionesContainerFiguras"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:background="@drawable/card_figuras_pregunta_bg"
                android:elevation="6dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:id="@+id/preguntaTextViewFiguras"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/pregunta_figuras"
                    android:textColor="@color/primary_blue"
                    android:textSize="26sp"
                    android:fontFamily="@font/nunito_extrabold"
                    android:textStyle="normal" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardContenedorFiguras"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:background="@drawable/card_figuras_pregunta_bg"
                android:elevation="6dp"
                android:padding="28dp">

                <ImageView
                    android:id="@+id/figuraImageView"
                    android:layout_width="290dp"
                    android:layout_height="290dp"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/exercise_figuras" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnVolverFiguras"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="4dp"
        android:layout_marginBottom="4dp"
        android:minWidth="120dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="@string/historial_atras"
        android:onClick="onVolverClicked"
        style="@style/KidAppButtonSecondary" />

</RelativeLayout>
